{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/backend",
    "rootDir": "src/backend",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "types": ["node"]
  },
  "include": [
    "src/backend/**/*",
    "src/types/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
