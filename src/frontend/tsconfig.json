{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": "../..",
    "paths": {
      "@/types": [
        "packages/types/src"
      ],
      "@/types/*": [
        "packages/types/src/*"
      ],
      "@/shared": [
        "src/shared"
      ],
      "@/shared/*": [
        "src/shared/*"
      ],
      "@/backend/*": [
        "src/backend/*"
      ],
      "@/frontend/*": [
        "src/frontend/*"
      ],
      "@/plugins/*": [
        "src/plugins/*"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
