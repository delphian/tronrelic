{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/types": ["packages/types/src"],
      "@/types/*": ["packages/types/src/*"],
      "@delphian/tronrelic-types": ["packages/types/src"],
      "@delphian/tronrelic-types/*": ["packages/types/src/*"],
      "socket.io": ["node_modules/socket.io"],
      "socket.io/*": ["node_modules/socket.io/*"],
      "socket.io-client": ["node_modules/socket.io-client"],
      "socket.io-client/*": ["node_modules/socket.io-client/*"],
      "mongodb": ["node_modules/mongodb"],
      "mongodb/*": ["node_modules/mongodb/*"],
      "@/shared": ["src/shared"],
      "@/shared/*": ["src/shared/*"],
      "@/backend/*": ["src/backend/*"],
      "@/frontend/*": ["src/frontend/*"],
      "@/plugins/*": ["src/plugins/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".next",
    "src/frontend/.next",
    "src/plugins/**"
  ]
}
