{
  "name": "tronrelic",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "src/plugins/*"],
  "description": "TRON blockchain analytics platform with real-time monitoring, whale tracking, and extensible plugins.",
  "repository": {
    "type": "git",
    "url": "https://github.com/delphian/tronrelic.git"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "tsx watch --exclude 'src/**/plugins.generated.ts' src/backend/index.ts",
    "dev:frontend": "next dev --port 3000 src/frontend",
    "dev:servers": "concurrently -n backend,frontend -c blue,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build:types && npm run build:backend && npm run build:frontend",
    "build:types": "npm --workspace @delphian/tronrelic-types run build",
    "build:backend": "node scripts/build-backend.mjs",
    "build:frontend": "npm run generate:plugins && next build src/frontend",
    "stop": "docker compose -f docker-compose.npm.yml down",
    "stop:termux": "node scripts/stop-termux.mjs",
    "clean": "rimraf dist .next src/frontend/.next src/plugins/*/dist src/frontend/public/plugins coverage test-results playwright-report playwright/.cache && find . -name '*.tsbuildinfo' -delete && node scripts/reset-generated.mjs",
    "reset": "docker compose -f docker-compose.npm.yml down -v",
    "typecheck": "tsc --noEmit",
    "typecheck:core": "npm run clean && npm run typecheck",
    "typecheck:backend": "tsc --noEmit -p tsconfig.backend.json",
    "typecheck:frontend": "tsc --noEmit -p src/frontend/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:plugins": "for dir in src/plugins/*/; do (cd \"$dir\" && npm test); done",
    "typecheck:plugins": "for dir in src/plugins/*/; do (cd \"$dir\" && npm run typecheck --if-present); done",
    "test:integration": "npx playwright test",
    "lint": "eslint src/",
    "generate:plugins": "node scripts/generate-backend-plugin-registry.mjs && node scripts/generate-frontend-plugin-registry.mjs",
    "docker:build": "docker compose build",
    "docker:build:prod": "ENV=production docker compose build",
    "docker:up": "docker compose up -d",
    "docker:up:prod": "ENV=production docker compose up -d",
    "docker:down": "docker compose down",
    "docker:down:prod": "ENV=production docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:logs:backend": "docker compose logs -f backend",
    "docker:logs:frontend": "docker compose logs -f frontend",
    "docker:clean": "docker compose down -v && docker system prune -f",
    "docker:rebuild": "docker compose down && docker compose build --no-cache && docker compose up -d",
    "setup": "./scripts/setup.sh"
  },
  "dependencies": {
    "@clickhouse/client": "^1.8.1",
    "@noble/hashes": "^1.8.0",
    "@reduxjs/toolkit": "^2.2.5",
    "@scure/bip32": "^1.4.0",
    "@scure/bip39": "^1.3.0",
    "@types/multer": "^2.0.0",
    "axios": "^1.7.5",
    "bullmq": "^5.8.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "elliptic": "^6.6.1",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "geoip-lite": "^1.4.10",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.4.1",
    "ipaddr.js": "^2.2.0",
    "js-sha3": "^0.8.0",
    "js-yaml": "^4.1.1",
    "lucide": "^0.555.0",
    "lucide-react": "^0.545.0",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "next": "^15.5.7",
    "node-cron": "^3.0.3",
    "pino": "^9.3.2",
    "pino-pretty": "^13.1.2",
    "playwright": "^1.55.1",
    "postcss": "^8.5.6",
    "prom-client": "^15.1.3",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "rehype": "^13.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tronweb": "^5.3.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/elliptic": "^6.4.18",
    "@types/express": "^4.17.21",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/geoip-lite": "^1.4.4",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.9",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.27.2",
    "esbuild-sass-plugin": "^3.3.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.7",
    "rimraf": "^5.0.5",
    "sass": "^1.97.1",
    "tsx": "^4.19.1",
    "typescript": "~5.6.2",
    "vitest": "^4.0.1"
  }
}
