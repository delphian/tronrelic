{
    "name": "@delphian/tronrelic-types",
    "version": "1.0.0",
    "description": "Core type definitions for the TronRelic platform",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "prepare": "npm run build",
        "prepublishOnly": "npm run build"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/delphian/tronrelic.git",
        "directory": "packages/types"
    },
    "license": "AGPL-3.0-or-later",
    "peerDependencies": {
        "axios": "^1.0.0",
        "mongodb": "^6.0.0",
        "react": "^18.0.0 || ^19.0.0",
        "socket.io": "^4.0.0",
        "socket.io-client": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "axios": { "optional": true },
        "mongodb": { "optional": true },
        "react": { "optional": true },
        "socket.io": { "optional": true },
        "socket.io-client": { "optional": true }
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/react": "^18.2.46",
        "axios": "^1.7.5",
        "mongodb": "^6.0.0",
        "socket.io": "^4.7.5",
        "socket.io-client": "^4.7.5",
        "typescript": "~5.6.2"
    }
}
